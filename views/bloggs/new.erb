<h2>New post</h2>

<form action="/bloggs" method="post">
    <label> Header
        <input type="text" name="heading">
    </label>
    <label> Description
        <input type="text" name="description">
    </label>
     <label> Category
        <select name="category_id">
            <% @categories.each do |cat| %>
            <option value="<%= cat["id"]%>">
            <%= cat["category_title"] %>
            </option>
          <% end %>
        </select>
    </label>
    

    <input type="submit" value="Spara">
</form>
